/* Leet 2685. Count the Number of Complete Components
 *
 * Solution translated from Python
 * 1. DFS finding components
 * 2. completeness checked by handshaking lemma
 */

class Solution {
    private List<Integer>[] adj; //adjacency list
    private boolean[] visited;

    public int countCompleteComponents(int n, int[][] edges) {
        // Build adjacency list
        this.adj = new ArrayList[n];    
        for (int v=0; v<n; v++) {
            this.adj[v] = new ArrayList<>();
        }
        for (int[] e : edges){
            adj[e[0]].add(e[1]);
            adj[e[1]].add(e[0]);
        }

        int count = 0;
        visited = new boolean[n]; // vertices unvisited

        for (int v=0; v<n; v++){
            if (!this.visited[v]) {
                ArrayList<Integer> comp = new ArrayList<>();
                dfs(v, comp);

                int E2 = 0; // twice # edges of component
                for (int w : comp)
                    E2 += adj[w].size();

                int V = comp.size(); // # vertices of component
                if (E2 == V*(V-1))
                    count++;
            } 
        }
        return count;
    }
    
    private void dfs(int v, ArrayList<Integer> curr_comp){
        this.visited[v] = true;
        curr_comp.add(v);
        for (int nb : this.adj[v]) {
            if (!this.visited[nb])
                dfs(nb, curr_comp);
        }
    }

}
